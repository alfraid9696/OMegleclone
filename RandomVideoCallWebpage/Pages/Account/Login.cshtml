@page
@model RandomVideoCallWebpage.Pages.Account.LoginModel
@{
    ViewData["Title"] = "Login";
}

<div class="auth-page">
    <div class="auth-card auth-card-narrow">
        <div class="auth-card-header">
            <h1>Welcome back</h1>
            <p>Log in to start random video chat.</p>
        </div>

        <form method="post" class="auth-form" novalidate>
            <input type="hidden" asp-for="ReturnUrl" />
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="Input.Email" class="form-label">Email</label>
                <input asp-for="Input.Email" class="form-control" placeholder="you@example.com" />
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Input.Password" class="form-label">Password</label>
                <input asp-for="Input.Password" class="form-control" />
                <span asp-validation-for="Input.Password" class="text-danger"></span>
            </div>

            <div class="form-check mb-4">
                <input asp-for="Input.RememberMe" class="form-check-input" />
                <label asp-for="Input.RememberMe" class="form-check-label"></label>
            </div>

            <button type="submit" class="btn auth-btn-primary w-100">Log in</button>
        </form>

        <p class="auth-switch mt-4 mb-0">
            Don't have an account?
            <a asp-page="/Account/Register">Register</a>
        </p>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
