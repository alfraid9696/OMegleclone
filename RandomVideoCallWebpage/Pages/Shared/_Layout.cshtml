<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Strangers Call</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/RandomVideoCallWebpage.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/chat.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/auth.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
</head>
@inject UserManager<ApplicationUser> UserManager
@{
    var greetingName = User.Identity?.Name;
    if (User.Identity?.IsAuthenticated == true)
    {
        var currentUser = await UserManager.GetUserAsync(User);
        if (!string.IsNullOrWhiteSpace(currentUser?.DisplayName))
        {
            greetingName = currentUser.DisplayName;
        }
    }
}
<body class="app-body">
    <header class="app-header">
        <nav class="navbar navbar-expand-md app-navbar">
            <div class="container">
                <a class="navbar-brand app-brand" asp-area="" asp-page="/Index">Strangers Call</a>

                <button class="navbar-toggler app-toggler" type="button" data-bs-toggle="collapse"
                        data-bs-target="#mainNav" aria-controls="mainNav" aria-expanded="false"
                        aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="mainNav">
                    <ul class="navbar-nav ms-auto align-items-md-center">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item">
                                <span class="app-user-name">@greetingName</span>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link app-nav-link @(ViewContext.RouteData.Values["page"]?.ToString() == "/Profile" ? "active" : "")"
                                   asp-page="/Profile">Profile</a>
                            </li>
                            <li class="nav-item ms-md-2">
                                <form method="post" asp-page="/Account/Logout" class="d-inline">
                                    <button type="submit" class="btn btn-sm app-btn-ghost">Logout</button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link app-nav-link" asp-page="/Account/Login">Login</a>
                            </li>
                            <li class="nav-item ms-md-2">
                                <a class="btn btn-sm app-btn-primary" asp-page="/Account/Register">Register</a>
                            </li>
                            <li class="nav-item ms-md-2">
                                <a class="nav-link app-nav-link" asp-page="/Admin/Login">Admin login</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main class="app-main">
        <div class="container">
            @RenderBody()
        </div>
    </main>

    <footer class="app-footer">
        <div class="container app-footer-inner">
            <p class="footer-brand">&copy; 2026 Strangers Call</p>
            <p class="footer-dev">
                Developed by <strong>Ankit Chuarasiya</strong>
            </p>
            <p class="footer-tech">
                ASP.NET Core 8 &middot; SignalR &middot; WebRTC &middot; Entity Framework &middot; SQL Server &middot; Bootstrap
            </p>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
