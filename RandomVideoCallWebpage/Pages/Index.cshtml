@page
@model IndexModel

<div class="container">

    <h1 class="text-center mt-3">
        Random Video Chat
    </h1>

    <p id="statusText" class="text-center text-muted mt-2">
        Connecting...
    </p>

    <div class="text-center mt-3">

        <button id="startBtn"
                class="btn btn-success">
            Start Chat
        </button>

        <button id="nextBtn"
                class="btn btn-danger"
                disabled>
            Next Stranger
        </button>

    </div>

    <div class="row mt-4">

        <div class="col-md-6">

            <h4>Stranger</h4>

            <video id="remoteVideo"
                   autoplay
                   playsinline
                   class="video-box">
            </video>

        </div>

        <div class="col-md-6">

            <h4>You</h4>

            <video id="localVideo"
                   autoplay
                   muted
                   playsinline
                   class="video-box">
            </video>

        </div>

    </div>

    <div class="mt-4">

        <div id="messages"
             class="message-area">
        </div>

        <div class="input-group mt-3">

            <input id="messageInput"
                   class="form-control"
                   placeholder="Type message..."
                   disabled />

            <button id="sendBtn"
                    class="btn btn-primary"
                    disabled>
                Send
            </button>
           
        </div>

    </div>

</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.7/signalr.min.js"></script>
    <script src="~/js/chat.js" asp-append-version="true"></script>
}